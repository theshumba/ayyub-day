rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function household(hid) {
      return get(/databases/$(database)/documents/households/$(hid)).data;
    }
    function isOwner(hid) {
      return request.auth != null && request.auth.uid == household(hid).ownerUid;
    }
    function isMember(hid) {
      return request.auth != null &&
        (request.auth.uid == household(hid).ownerUid || request.auth.uid == household(hid).wifeUid);
    }

    match /households/{hid} {
      // Owner or linked wife may read the household doc itself.
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.ownerUid || request.auth.uid == resource.data.wifeUid);
      // Household id must equal the owner's uid (our convention).
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerUid && hid == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      // Reassurance status: owner writes, wife reads.
      match /shared/{doc} {
        allow read: if isMember(hid);
        allow write: if isOwner(hid);
      }

      // Everything private (savings, weight, quotas): owner only. Wife is denied.
      match /private/{doc=**} {
        allow read, write: if isOwner(hid);
      }
    }
  }
}
