rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the reassurance status syncs. It holds no sensitive data (where he is,
    // prayer times, time-together, date night) and lives under a long unguessable
    // household id shared only with his wife — a capability ("anyone with the link")
    // model. Private data (savings, weight, quotas) never leaves his device.
    match /households/{hid}/shared/{doc} {
      allow read, write: if true;
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
